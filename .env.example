# =============================================================================
# .env.example — copy to .env and fill in real values before docker compose up
# =============================================================================

# -----------------------------------------------------------------------------
# Public reachability
# -----------------------------------------------------------------------------
# Domain Caddy serves on. Use 'localhost' for local dev (Caddy will produce a
# self-signed cert), or a real domain that resolves to this host for prod.
DOMAIN=localhost

# Used both by Caddy (Let's Encrypt) and as the public origin for presigned
# MinIO URLs. MUST match the scheme + host the mobile/web clients hit.
PUBLIC_BASE_URL=https://localhost

# Email registered with Let's Encrypt
ACME_EMAIL=ops@example.com

# Comma-separated list of allowed CORS origins (the API enforces these)
CORS_ORIGINS=https://localhost,http://localhost:5173

# -----------------------------------------------------------------------------
# Postgres
# -----------------------------------------------------------------------------
# Superuser — only used inside the container for init
POSTGRES_PASSWORD=replace-with-strong-password

# App roles (created by infra/postgres/init/01-roles-and-extensions.sh)
APP_USER_PASSWORD=replace-with-strong-password
APP_ADMIN_PASSWORD=replace-with-strong-password

# -----------------------------------------------------------------------------
# MinIO
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=farmerp-admin
MINIO_ROOT_PASSWORD=replace-with-strong-password-min-8-chars

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=replace-with-strong-password

# -----------------------------------------------------------------------------
# JWT secrets — generate with `openssl rand -base64 48`
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=replace-with-48-bytes-of-base64
JWT_REFRESH_SECRET=replace-with-different-48-bytes-of-base64

# -----------------------------------------------------------------------------
# MQTT
# -----------------------------------------------------------------------------
# Plain MQTT port. For production switch to 8883 with TLS certs and update
# mosquitto.conf accordingly.
MQTT_PORT=1883
